<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aynı WiFi'deki cihaz aranıyor..."
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/pttButton"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="BASILI TUT VE KONUŞ"
        android:textSize="14sp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Uygulamayı kapatsan bile ekranda yeşil bir 'KONUŞ' butonu belirir, arka planda dinlemeye devam eder."
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
